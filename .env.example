# Copy this file to .env and fill in the values. Never commit .env.

# Which prescription reader to use: gemini | anthropic | textract
PRESCRIPTION_PROVIDER=gemini

# Gemini (default provider). Free tier, no billing: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-lite-latest

# Anthropic / Claude (when PRESCRIPTION_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# AWS Textract (when PRESCRIPTION_PROVIDER=textract).
# Textract does OCR and Gemini interprets the text, so this mode also needs GEMINI_API_KEY.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Supabase (from Alan, or your own project's API settings)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
